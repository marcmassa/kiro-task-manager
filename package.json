{
  "name": "task-manager",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run server.ts",
    "build": "bun build ./src/index.tsx --outdir ./public/dist --target browser",
    "build:css": "bunx tailwindcss -i ./src/styles.css -o ./public/styles.css --minify",
    "build:all": "bun run build:css && bun run build",
    "mcp": "bun run mcp-server.ts",
    "start": "bun run server.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1072.0",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@elysiajs/cors": "^1.0.0",
    "@elysiajs/static": "^1.0.0",
    "@lobehub/icons": "^5.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "elysia": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "bun-types": "^1.3.14",
    "fast-check": "^4.8.0",
    "postcss": "^8.4.0",
    "prettier": "3.8.4",
    "tailwindcss": "^3.4.0"
  }
}
